# Copy to .env: cp .env.example .env
#
VITE_APP_BASE_PATH=/sports-data-admin
#
# Dev only — default is {VITE_APP_BASE_PATH}/api (Vite → timeline-scraper :4011)
# VITE_SCRAPPER_API_BASE_URL=/sports-data-admin/api
#
# Browser sends this Bearer token to the UI /api/* proxy (matches ADMIN_UI_API_KEY on the Node server).
VITE_ADMIN_UI_API_KEY=
ADMIN_UI_API_KEY=

# Dev only — Vite proxy replaces the browser token with this when calling timeline-scraper.
SCRAPPER_ADMIN_API_KEY=
