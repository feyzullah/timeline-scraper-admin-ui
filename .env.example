# Copy to .env: cp .env.example .env
#
# App mount path (no trailing slash). Assets, routes, and API proxy share this prefix.
VITE_APP_BASE_PATH=/sports-data-admin
#
# Dev only — leave unset to use {VITE_APP_BASE_PATH}/scrapper-api (Vite proxies to timeline-scraper).
# VITE_SCRAPPER_API_BASE_URL=/sports-data-admin/scrapper-api
#
# Dev only — prod injects SCRAPPER_ADMIN_API_KEY server-side from k8s secret.
VITE_SCRAPPER_ADMIN_API_KEY=
