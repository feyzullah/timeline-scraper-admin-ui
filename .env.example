# Copy to .env: cp .env.example .env
#
# App mount path (no trailing slash). Assets and routes live under this prefix.
VITE_APP_BASE_PATH=/sports-data-admin
#
# Optional override; default is {VITE_APP_BASE_PATH}/scrapper-api
# VITE_SCRAPPER_API_BASE_URL=/sports-data-admin/scrapper-api
#
# Same as SCRAPPER_ADMIN_API_KEY in timeline-scraper/.env (dev only; prod server injects Bearer).
VITE_SCRAPPER_ADMIN_API_KEY=
