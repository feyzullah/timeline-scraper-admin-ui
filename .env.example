# Copy to .env: cp .env.example .env
#
# API base (Settings → localStorage overrides these after first visit):
#   Recommended for `npm run dev` — same-origin; Vite proxies to timeline-scraper :4011
VITE_SCRAPPER_API_BASE_URL=/scrapper-api
#
# Avoid http://127.0.0.1:5174/... when you open http://localhost:5174 (different origins).
# Direct to scrapper (browser CORS): http://127.0.0.1:4011
#
# Same value as SCRAPPER_ADMIN_API_KEY in timeline-scraper/.env
VITE_SCRAPPER_ADMIN_API_KEY=
