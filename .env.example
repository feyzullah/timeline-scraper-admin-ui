# Copy to .env: cp .env.example .env
#
# Local dev — same-origin; Vite proxies /scrapper-api → timeline-scraper :4011
VITE_SCRAPPER_API_BASE_URL=/scrapper-api
#
# Same as SCRAPPER_ADMIN_API_KEY in timeline-scraper/.env (dev only; optional in prod Docker/k8s
# where nginx injects Bearer on /scrapper-api).
VITE_SCRAPPER_ADMIN_API_KEY=
