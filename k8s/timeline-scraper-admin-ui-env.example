# Secret `timeline-scraper-admin-ui-env` (namespace timeline-scraper).
# All keys loaded via envFrom in k8s/deployment.yaml.
#
#   kubectl create secret generic timeline-scraper-admin-ui-env \
#     --from-env-file=timeline-scraper-admin-ui-env.production \
#     -n timeline-scraper

# In-cluster scrapper root — UI forwards /sports-data-admin/api/* with the browser admin Bearer token.
SCRAPPER_UPSTREAM=http://timeline-scraper:4011

# Admin auth uses SCRAPPER_ADMIN_API_KEY on timeline-scraper (same secret as timeline-scraper-env).
# Operator/settler keys live in Mongo api_keys — managed via admin UI, not stored here.
