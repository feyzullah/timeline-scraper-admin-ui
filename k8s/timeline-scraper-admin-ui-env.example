# Secret `timeline-scraper-admin-ui-env` (namespace timeline-scraper).
# All keys loaded via envFrom in k8s/deployment.yaml.
#
#   kubectl create secret generic timeline-scraper-admin-ui-env \
#     --from-env-file=timeline-scraper-admin-ui-env.production \
#     -n timeline-scraper

# Browser → UI server (/sports-data-admin/api/*). Operators paste this into Settings.
ADMIN_UI_API_KEY=

# UI server → timeline-scraper. Must match SCRAPPER_ADMIN_API_KEY on timeline-scraper-env.
SCRAPPER_ADMIN_API_KEY=

# In-cluster scrapper root — UI forwards /sports-data-admin/api/* here unchanged.
SCRAPPER_UPSTREAM=http://timeline-scraper:4011
